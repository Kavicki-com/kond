{
  "expo": {
    "name": "Kond",
    "slug": "kond",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "owner": "kavickicom",
    "userInterfaceStyle": "automatic",
    "scheme": "kond",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kavicki.kond",
      "infoPlist": {
        "NSCameraUsageDescription": "Precisamos da câmera para fotografar encomendas e ler QR Codes.",
        "NSPhotoLibraryUsageDescription": "Para selecionar fotos de encomendas.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.kavicki.kond",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Precisamos da câmera para fotografar encomendas e ler QR Codes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6c5ce7"
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "327e59f1-9605-4dc2-8568-377c57bcdad6"
      }
    }
  }
}